{
  "name": "santtu-nurmi-portfolio",
  "version": "2.0",
  "private": true,
  "description": "Portfolio website",
  "author": "Santtu Nurmi",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/santtunurmi/santtunurmi.github.io.git"
  },
  "homepage": "https://santtunurmi.netlify.app/",
  "scripts": {
    "build": "npm run css",
    "js-compile": "esbuild index.js --bundle --outfile=./docs/javascript/bundle.js",
    "css-compile": "sass ./scss/main.scss ./docs/css/stylesheet.css",
    "css-prefix": "postcss --replace docs/css/stylesheet.css --use autoprefixer --map",
    "css": "npm-run-all css-compile css-prefix js-compile"
  },
  "dependencies": {
    "@popperjs/core": "^2.11.8",
    "bootstrap": "^5.3.8",
    "bootstrap-icons": "^1.10.3",
    "jquery": "^3.6.4"
  },
  "devDependencies": {
    "autoprefixer": "^10.4.14",
    "esbuild": "0.27.1",
    "npm-run-all": "^4.1.5",
    "postcss": "^8.4.21",
    "postcss-cli": "^10.1.0",
    "sass": "^1.95.1"
  }
}
